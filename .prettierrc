{
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": true,
  "quoteProps": "as-needed",
  "trailingComma": "es5",
  "bracketSpacing": true,
  "arrowParens": "avoid",
  "overrides": [
    {
      "files": ["*.sass", "*.scss"],
      "options": {
        "tabWidth": 2,
        "useTabs": false,
        "printWidth": 120
      }
    }
  ]
}